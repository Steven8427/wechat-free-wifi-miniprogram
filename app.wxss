/* app.wxss - 全局样式 */

page {
  background: #EDEDED;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #1a1a1a;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background: #EDEDED;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}
