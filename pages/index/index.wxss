/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: #EDEDED;
}

/* ===== Hero区域 ===== */
.hero {
  background: linear-gradient(135deg, #07C160 0%, #0AD775 100%);
  padding: 80rpx 40rpx 80rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: -40%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 60%);
}

.wifi-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.wifi-symbol {
  font-size: 64rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== WiFi信息卡片 ===== */
.info-card {
  margin: -40rpx 30rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 10rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #888;
}

.value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.value.signal {
  color: #07C160;
  font-weight: 600;
}

/* ===== 广告提示 ===== */
.ad-notice {
  margin: 0 30rpx 24rpx;
  background: linear-gradient(135deg, #FFF9ED 0%, #FFF3DB 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.ad-notice-icon {
  width: 72rpx;
  height: 72rpx;
  background: #F5A623;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.play-icon {
  color: #fff;
  font-size: 32rpx;
}

.ad-notice-text {
  display: flex;
  flex-direction: column;
}

.ad-notice-text .bold {
  font-size: 28rpx;
  font-weight: 600;
  color: #8B6914;
  margin-bottom: 4rpx;
}

.ad-notice-text .sub {
  font-size: 24rpx;
  color: #B8941F;
}

/* ===== 连接按钮 ===== */
.connect-btn {
  margin: 16rpx 30rpx 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: #07C160 !important;
  color: #fff !important;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 30rpx rgba(7,193,96,0.3);
}

.connect-btn::after {
  border: none;
}

/* ===== 连接中 ===== */
.connecting-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.connecting-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(7,193,96,0.2);
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.connecting-text {
  font-size: 28rpx;
  color: #888;
}

/* ===================================================
   自定义广告弹层
   =================================================== */

.ad-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.ad-modal {
  width: 100%;
  max-width: 650rpx;
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  animation: adPopIn 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes adPopIn {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* 广告头部 */
.ad-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  background: #f9f9f9;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}

.ad-header-label {
  font-size: 24rpx;
  color: #aaa;
  background: #eee;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.ad-countdown-wrap {
  display: flex;
  align-items: center;
}

.ad-countdown {
  font-size: 24rpx;
  color: #999;
}

.ad-close-btn {
  padding: 6rpx 20rpx;
  background: #07C160;
  border-radius: 24rpx;
}

.ad-close-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 广告内容 */
.ad-body {
  width: 100%;
  min-height: 600rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
}

.ad-image {
  width: 100%;
  height: 600rpx;
}

/* 无图默认样式 */
.ad-default {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.ad-default-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.ad-default-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.ad-default-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  text-align: center;
  line-height: 1.6;
}

/* 广告底部 */
.ad-footer {
  padding: 20rpx 28rpx 28rpx;
  background: #fff;
}

.ad-progress {
  height: 6rpx;
  background: #eee;
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.ad-progress-bar {
  height: 100%;
  background: #07C160;
  border-radius: 3rpx;
  transition: width 0.3s linear;
}

.ad-footer-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
}

/* ===== WiFi列表模式 ===== */
.wifi-list {
  margin: -40rpx 30rpx 24rpx;
  position: relative;
  z-index: 2;
}

.wifi-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
}

.wifi-list-item:active {
  background: #f5f5f5;
  transform: scale(0.98);
}

.wifi-list-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.wifi-list-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.wifi-list-shop {
  font-size: 24rpx;
  color: #999;
}

.wifi-list-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}