/* pages/list/list.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #07C160 0%, #06D66B 100%);
  padding: 40rpx 32rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.6);
  flex-shrink: 0;
}

.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.nickname {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.create-header-btn {
  padding: 12rpx 28rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  line-height: 1.5;
}

/* ===== 搜索 ===== */
.search-bar {
  margin: 24rpx 24rpx 16rpx;
  background: #fff;
  border-radius: 48rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  height: 80rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #bbb;
  padding: 10rpx;
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid rgba(7,193,96,0.2);
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* ===== 空状态 ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: #07C160;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 16rpx 60rpx;
  border: none;
  line-height: 1.5;
}

/* ===== WiFi卡片 ===== */
.list-wrap {
  padding: 0 24rpx;
}

.wifi-card {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-right: 20rpx;
}

.card-shopname {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.card-ssid {
  font-size: 24rpx;
  color: #888;
}

.card-count {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.count-num {
  color: #07C160;
  font-weight: 700;
  font-size: 28rpx;
}

.card-qrcode {
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.qrcode-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.qrcode-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-placeholder-text {
  font-size: 48rpx;
}

/* ===== 操作按钮 ===== */
.card-actions {
  background: #fff;
  border-radius: 0 0 20rpx 20rpx;
  padding: 0 28rpx 24rpx;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.manage-btn {
  background: #07C160;
  color: #fff;
}

.delete-btn {
  background: #f5f5f5;
  color: #999;
}
