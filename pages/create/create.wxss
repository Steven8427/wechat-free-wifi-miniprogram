/* pages/create/create.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

/* ===== Banner ===== */
.banner {
  background: linear-gradient(135deg, #07C160 0%, #06D66B 100%);
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
  color: #fff;
}

.banner-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.banner-sub {
  font-size: 26rpx;
  opacity: 0.85;
}

/* ===== Features ===== */
.features {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #666;
}

.feature-icon {
  font-size: 28rpx;
}

/* ===== Form ===== */
.form-card {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-of-type {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.form-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #07C160;
}

.tip-icon {
  font-size: 26rpx;
}

/* ===== Create Button ===== */
.create-btn {
  margin: 0 24rpx 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: #07C160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.3);
}

.create-btn[disabled] {
  background: #8ED8B0;
  color: #fff;
}

/* ===== My WiFi List ===== */
.my-list {
  margin: 0 24rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.list-item-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.list-item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.list-item-ssid {
  font-size: 24rpx;
  color: #999;
}

.list-item-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.view-btn {
  background: #07C160;
  color: #fff;
}

.del-btn {
  background: #f5f5f5;
  color: #999;
}

/* ===== Result Page ===== */
.result-page {
  padding: 40rpx 24rpx;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
  margin-bottom: 32rpx;
}

.result-header {
  margin-bottom: 30rpx;
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.result-sub {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.qrcode-wrap {
  margin: 0 auto 24rpx;
  width: 400rpx;
  height: 400rpx;
}

.qrcode-img {
  width: 100%;
  height: 100%;
}

.result-ssid {
  font-size: 36rpx;
  font-weight: 700;
  color: #07C160;
  margin-bottom: 8rpx;
}

.result-tip {
  font-size: 24rpx;
  color: #999;
}

/* ===== Result Actions ===== */
.result-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.save-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #07C160;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.back-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #333;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: 2rpx solid #ddd;
}

.home-link {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #07C160;
  margin: 24rpx 0;
}

.result-hint {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
}
