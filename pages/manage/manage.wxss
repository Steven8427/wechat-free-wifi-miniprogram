/* pages/manage/manage.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

/* ===== 海报 ===== */
.poster {
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  transition: background 0.3s;
}

.poster-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.poster-sub {
  display: block;
  font-size: 24rpx;
  margin-bottom: 32rpx;
}

.qrcode-wrap {
  width: 360rpx;
  height: 360rpx;
  margin: 0 auto 28rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  box-sizing: border-box;
}

.qrcode-img {
  width: 100%;
  height: 100%;
}

.qrcode-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.placeholder-text {
  font-size: 80rpx;
}

.ssid-banner {
  border-radius: 12rpx;
  padding: 20rpx 28rpx;
}

.ssid-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.ssid-sub {
  display: block;
  font-size: 24rpx;
}

/* ===== 提示 ===== */
.theme-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 32rpx;
}

/* ===== 操作按钮 ===== */
.actions {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 44rpx;
}

.action-label {
  font-size: 24rpx;
  color: #666;
}

/* ===== 隐私弹窗 ===== */
.privacy-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
}

.privacy-box {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  width: 620rpx;
  z-index: 1;
}

.privacy-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 24rpx;
}

.privacy-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 40rpx;
}

.privacy-btns {
  display: flex;
  gap: 20rpx;
}

.privacy-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5 !important;
  color: #666 !important;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.privacy-cancel::after { border: none; }

.privacy-agree {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #07C160 !important;
  color: #fff !important;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.privacy-agree::after { border: none; }
