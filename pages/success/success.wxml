<!-- pages/success/success.wxml -->
<view class="container">

<view class="success-icon-wrap">
  <text class="success-icon">✓</text>
</view>

<text class="success-title">连接成功！</text>
<text class="success-sub">您已成功连接到WiFi网络</text>

<view class="detail-card">
  <view class="detail-row">
    <text class="label">WiFi名称</text>
    <text class="value">{{ssid}}</text>
  </view>
  <view class="detail-row">
    <text class="label">连接状态</text>
    <text class="value connected">● 已连接</text>
  </view>
  <view class="detail-row" wx:if="{{ip}}">
    <text class="label">IP地址</text>
    <text class="value">{{ip}}</text>
  </view>
  <view class="detail-row">
    <text class="label">免费时长</text>
    <text class="value">不限时</text>
  </view>
</view>

<!-- 安卓连接说明 -->
<view class="android-options" wx:if="{{isAndroid}}">
  <view class="android-options-header">
    <text class="android-options-badge">安卓用户须知</text>
    <text class="android-options-title">如何保持WiFi不断开？</text>
  </view>

  <!-- 选项A：保持后台 -->
  <view class="option-card option-a">
    <view class="option-tag tag-easy">简单</view>
    <text class="option-title">保持小程序在后台运行</text>
    <text class="option-desc">点击右上角 ⊙ 退出小程序，不要清理微信后台，WiFi即可保持连接。</text>
    <button class="option-btn option-btn-a" bindtap="onDone">点击 ⊙ 退出</button>
  </view>

  <!-- 分隔 -->
  <view class="option-divider"><text class="option-or">或者</text></view>

  <!-- 选项B：永久连接 -->
  <view class="option-card option-b">
    <view class="option-tag tag-permanent">永久</view>
    <text class="option-title">去系统设置手动连接（推荐）</text>
    <text class="option-desc">即使关闭微信也不会断网，一劳永逸。</text>
    <view class="step-list">
      <view class="step-item">
        <view class="step-num">1</view>
        <text class="step-text">密码已自动复制到剪贴板</text>
      </view>
      <view class="step-item">
        <view class="step-num">2</view>
        <text class="step-text">打开手机「设置」→「WLAN」</text>
      </view>
      <view class="step-item">
        <view class="step-num">3</view>
        <text class="step-text">找到「{{ssid}}」，粘贴密码连接</text>
      </view>
    </view>
    <view class="step-copy-row">
      <text class="step-password">WiFi: {{ssid}}</text>
      <button class="step-copy-btn" bindtap="onCopyPassword">重新复制</button>
    </view>
  </view>
</view>

<!-- iOS提示 -->
<view class="exit-tip" wx:if="{{!isAndroid}}">
  <text class="exit-tip-text">✅ 已连接，退出小程序WiFi保持正常</text>
</view>

<button class="done-btn" bindtap="onDone" wx:if="{{!isAndroid}}">完成</button>
<button class="share-btn" open-type="share">推荐给朋友</button>

</view>
