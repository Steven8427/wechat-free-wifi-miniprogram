/* pages/success/success.wxss */

.container {
  min-height: 100vh;
  background: #EDEDED;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 60rpx;
}

/* ===== 成功图标 ===== */
.success-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(7,193,96,0.3);
  animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes popIn {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 80rpx;
  color: #fff;
  font-weight: bold;
}

/* ===== 文字 ===== */
.success-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.success-sub {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 50rpx;
}

/* ===== 详情卡片 ===== */
.detail-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 10rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.detail-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #888;
}

.value {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.value.connected {
  color: #07C160;
  font-weight: 600;
}

/* ===== 退出提示 ===== */
.exit-tip {
  width: 100%;
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.exit-tip-text {
  font-size: 26rpx;
  color: #F57C00;
  line-height: 1.7;
  text-align: center;
  display: block;
}

/* ===== 按钮 ===== */
.done-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: #07C160 !important;
  color: #fff !important;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 30rpx rgba(7,193,96,0.3);
  margin-bottom: 24rpx;
}

.done-btn::after {
  border: none;
}

.share-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff !important;
  color: #07C160 !important;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.share-btn::after {
  border: none;
}

/* ===== 安卓两选项引导 ===== */
.android-options {
  width: 100%;
  margin-bottom: 32rpx;
}

.android-options-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.android-options-badge {
  display: inline-block;
  background: #FF6B35;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.android-options-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* 选项卡片 */
.option-card {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.option-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.tag-easy {
  background: #E8F5E9;
  color: #2E7D32;
}

.tag-permanent {
  background: #E3F2FD;
  color: #1565C0;
}

.option-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 10rpx;
}

.option-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.option-btn {
  width: 100% !important;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.option-btn::after { border: none; }

.option-btn-a {
  background: #07C160 !important;
  color: #fff !important;
}

/* 分隔线 */
.option-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24rpx 0;
}

.option-or {
  font-size: 24rpx;
  color: #999;
  padding: 0 20rpx;
}

/* 步骤列表 */
.step-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  background: #1890FF;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.step-copy-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-top: 8rpx;
}

.step-password {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
}

.step-copy-btn {
  background: #1890FF !important;
  color: #fff !important;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 10rpx;
  border: none;
  line-height: 1.5;
  height: auto;
  min-height: unset;
}

.step-copy-btn::after { border: none; }
